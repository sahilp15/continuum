# Continuum local development environment.
# Copy to .env and fill in values. Never commit real credentials.

# --- Core ---
NODE_ENV=development
DATABASE_URL=postgres://continuum:continuum_dev_password@localhost:5432/continuum

# --- Providers (mock mode runs without any of these) ---
# When CONTINUUM_PROVIDER_MODE=mock, all LLM/embedding/storage providers are
# deterministic mocks and no paid API keys are required.
CONTINUUM_PROVIDER_MODE=mock
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- MCP server ---
# Development-only bearer token for the local MCP server. The server refuses to
# start with dev-token auth when NODE_ENV=production.
CONTINUUM_MCP_DEV_TOKEN=

# --- Connectors (all optional; connectors run in mock mode without them) ---
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=
# GITHUB_APP_CLIENT_ID=
# GITHUB_APP_CLIENT_SECRET=

# --- Billing (feature-flagged, off by default) ---
CONTINUUM_BILLING_ENABLED=false
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
