# Continuum local development environment.
# Copy to .env and fill in values. Never commit real credentials.

# --- Core ---
NODE_ENV=development
# Database driver: "pglite" (default off-prod; embedded, no server needed) or
# "postgres" (default in production; requires DATABASE_URL). One schema + one
# migration history serve both.
# CONTINUUM_DB_DRIVER=pglite
# Postgres connection (required when the postgres driver is selected):
DATABASE_URL=postgres://continuum:continuum_dev_password@localhost:5432/continuum
# Optional: persist the local PGlite database to a directory (default is
# in-memory, which resets on server restart).
# CONTINUUM_PGLITE_DIR=.continuum/pglite

# --- Authentication (Better Auth — login/identity only) ---
# Required in production; a dev fallback is used when unset off-production.
# BETTER_AUTH_SECRET=
# Canonical app URL (production). In dev the origin is inferred from the request.
# BETTER_AUTH_URL=http://localhost:3000
# Google *login* OAuth client — identity only, scopes: openid email profile.
# This is DISTINCT from the Google Workspace connector app below; never share
# credentials or tokens between login and connector authorization.
# Callback URL: ${BETTER_AUTH_URL}/api/auth/callback/google
# GOOGLE_LOGIN_CLIENT_ID=
# GOOGLE_LOGIN_CLIENT_SECRET=
# Local test-login for Playwright/dev only. IMPOSSIBLE to enable in production
# (the env parser rejects it there and the route fails closed). Never set in prod.
# CONTINUUM_TEST_LOGIN=1

# --- Providers (mock mode runs without any of these) ---
# When CONTINUUM_PROVIDER_MODE=mock, all LLM/embedding/storage providers are
# deterministic mocks and no paid API keys are required.
CONTINUUM_PROVIDER_MODE=mock
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- MCP server ---
# Development-only bearer token for the local MCP server. The server refuses to
# start with dev-token auth when NODE_ENV=production.
CONTINUUM_MCP_DEV_TOKEN=

# --- Connectors ---
# Google Workspace connector — a SEPARATE OAuth app from Google login above,
# with Drive/Gmail/Calendar readonly scopes and its own consent + revocation.
# Absent these, the connector shows "Setup required" (never "Connected").
# GOOGLE_CONNECTOR_CLIENT_ID=
# GOOGLE_CONNECTOR_CLIENT_SECRET=
# Other connectors (placeholder / "Coming soon" until their real adapters land):
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=
# GITHUB_APP_CLIENT_ID=
# GITHUB_APP_CLIENT_SECRET=
# Connector credential encryption (Phase 5): versioned AES-256-GCM key material,
# stored OUTSIDE the database. Comma-separated `v<N>:<base64 32-byte key>`
# entries; the highest version is the active encryption key, older versions are
# kept so their ciphertext still decrypts until rotation re-seals it. Generate a
# key with:  node -e "console.log('v1:'+require('crypto').randomBytes(32).toString('base64'))"
# Rotate by appending a higher version (e.g. add v2:…) and re-sealing.
# CONTINUUM_CREDENTIAL_KEYS=v1:REPLACE_WITH_BASE64_32_BYTE_KEY

# --- Billing (feature-flagged, off by default) ---
CONTINUUM_BILLING_ENABLED=false
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
