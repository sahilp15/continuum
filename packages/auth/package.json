{
  "name": "@continuum/auth",
  "version": "0.1.0",
  "private": true,
  "description": "Authenticated actors and centralized authorization policies for Continuum. Authorization is never scattered across route handlers.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@continuum/contracts": "workspace:*"
  },
  "devDependencies": {
    "@continuum/testing": "workspace:*",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
