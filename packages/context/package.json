{
  "name": "@continuum/context",
  "version": "0.1.0",
  "private": true,
  "description": "The ContextCompiler: turns approved, authorized memory into the smallest trustworthy context bundle, with a Context Receipt for every request.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@continuum/auth": "workspace:*",
    "@continuum/contracts": "workspace:*",
    "@continuum/memory": "workspace:*"
  },
  "devDependencies": {
    "@continuum/testing": "workspace:*",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
